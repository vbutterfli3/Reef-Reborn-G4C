--- !u!1001 &325418168
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1273686864}
    m_Modifications:
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_FlipX
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: 1982789832, guid: f8ebbef08b2012d489582b630cf0600f, type: 3}
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_WasSpriteAssigned
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.size
      value: 17
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[0]
      value: 'Karen: "It''s been a bit since you''ve cleaned the reef but somehow
        the trash keeps coming back"  '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[1]
      value: 'Player: "I know, it''s so weird"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[2]
      value: 'Player: "Are the townspeople throwing their garbage in here?"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[3]
      value: 'Karen: "Yeah, they''ve been doing that a lot recently"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[4]
      value: 'Player: "But why would they do that? Do they know how much they''re
        harming your home?"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[5]
      value: 'Karen: "I''m not sure but some of the fish from the reef have swam
        back after hearing about the trash clean up" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[6]
      value: 'Karen: "Actually, Rain and I know this guy from above, he''s super
        informative"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[7]
      value: 'Player: "Rain? Who''s Rain?"  '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[8]
      value: 'Karen: "Oh you should go find her, look for a blue tang fish!"  '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[9]
      value: 'Karen: "You should explore the reef more, some coral has appeared and
        some of my friends came back too!!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[10]
      value: 'Player: "Really??? The coral is back?? Oh wait, your friends came back
        too!? Is Rain one of your friends?"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[11]
      value: 'Karen: "Yup, a while ago, one of the townspeople came into our reef
        and thats the guy I want you to find!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[12]
      value: 'Karen: "If I remember correctly, I think his name is Benny?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[13]
      value: 'Karen: "I know its a lot to ask, but can you still pick up some trash
        from the reef?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[14]
      value: 'Player: "Yeah of course, I''m not just going to stop helping you after
        a small change happens, I''m committed!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[15]
      value: 'Karen: "Aww thanks!! After you go exploring, do you think you can maybe
        go up to the town and go find Benny?"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[16]
      value: 'Player: "Sure, talk to you later" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[17]
      value: 'Karen: "Well, you can start by cleaning up some of the trash in the
        reef!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[18]
      value: 'Karen: "Some trash is bigger than others, so it may take a few tries,
        try and collect 12 pieces of trash"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[19]
      value: 'Karen: "But maybe the reef will finally start to recover!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2741854173681740130, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_LocalScale.x
      value: 1.7
      objectReference: {fileID: 0}
