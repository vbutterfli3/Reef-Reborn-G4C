    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.size
      value: 6
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[0]
      value: 'Rain: "Hi! Karen told me you''ve been helping the reef!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[1]
      value: 'Rain: "It''s really brave of you to be diving and cleaning around here"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[2]
      value: 'Player: "Thank you! I couldn''t believe how damaged the reef was" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[3]
      value: 'Rain: " Karen and I are best friends, we''ve been swimming around this
        reef since we were guppies"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[4]
      value: 'Player: "Karen has taught me a lot about the reef!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[5]
      value: 'Rain: "yeah that''s her, always very informative" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[6]
      value: 'Rain: "It''s reslly brave of you to be diving and cleaning around here"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[7]
      value: 'Karen: "Most of my friends have swam away to live in other waters"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[8]
      value: 'Player: "So.. are you all alone now?"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[9]
      value: 'Karen: "Well, I''m the only clownfish left, but there are some parrotfish
        who can withstand these conditions!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[10]
      value: 'Karen: "But most of the fish can''t handle the trash and heat"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[11]
      value: 'Karen: "Trash hurts all the animals that live here, even the coral"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[12]
      value: 'Karen: "My friends used to even mistake the trash for food!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[13]
      value: 'Player: "Coral???? What coral??"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[14]
      value: 'Karen: "Yeah, we don''t have much now, only some sea anenome and porites"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[15]
      value: 'Player: "Will your friends ever come back? Is there anything that I
        can do to help?"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[16]
      value: 'Karen: "You''ll help us?!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[17]
      value: 'Karen: "Well, you can start by cleaning up some of the trash in the
        reef!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[18]
      value: 'Karen: "Some trash is bigger than others, so it may take a few tries,
        try and collect 12 pieces of trash"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[19]
      value: 'Karen: "But maybe the reef will finally start to recover!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2741854173681740130, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_LocalScale.x
