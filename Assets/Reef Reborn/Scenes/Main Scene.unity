--- !u!1001 &1201850095
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 350834786}
    m_Modifications:
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_FlipX
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_Sprite
      value: 
      objectReference: {fileID: -610372826, guid: a92e324a63639c246a049f32e3115f7c, type: 3}
    - target: {fileID: 1224224317435694482, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_WasSpriteAssigned
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.size
      value: 7
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[0]
      value: 'Player: "Sorry to bother, but would you be willing to sign my petition
        on supporting our local reef?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[1]
      value: "Aur\xE9lie: \"Oh actually I'm just visiting for the month but my reef
        tour got cancelled today\" "
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[2]
      value: "Aur\xE9lie: \"I came all this way to see the famous coral reef but
        I had no idea it was struggling\""
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[3]
      value: 'Player: "Honestly, me too. I came here for the summer to dive in the
        water and see the wildlife but when I first got in, it was warm and covered
        with trash" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[4]
      value: "Aur\xE9lie: \"That's so sad, I know I'm not from here but if signing
        your petition helps, I'll do it!\" "
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[5]
      value: 'Player: "Thank you so much, just sign right here!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[6]
      value: "Aur\xE9lie: \"Good luck!\" "
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[7]
      value: 'Player: " Okay! Thank you so much!!!"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[8]
      value: 'Benny: "We got this! See you after you talk to the locals"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[9]
      value: 'Player: "Like a scientifical reason? So this isn''t just a weird phenomenon
        happening"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[10]
      value: 'Benny: "Nope and this might be a lot to take in but Australia is the
        3rd largest Fossil Fuel exporter, along with countries like Russia and the
        U.S."'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[11]
      value: 'Benny: "Those Fossil Fuels are then burned and release a Greenhouse
        Gas called Carbon Dioxide, you know, what we breath out and plants breath
        in?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[12]
      value: 'Player: "Yeah yeah I know about Carbon Dioxide, but what does any of
        this have to do with the reef being warm and dull??" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[13]
      value: 'Benny: "Just stay with me for a second, Carbon Dioxide hold heat in
        the Earth, which leads to Climate Change, meaning warmer temperatures in
        our air AND in our waters" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[14]
      value: 'Player: "Ohhhh I see I see, so thats why the reef feels so hot!! But
        how does that affect the coral?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[15]
      value: 'Benny: "Our reef is actually experiencing severe Coral Bleaching right
        now"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[16]
      value: 'Player: "What''s Coral Bleaching???" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[17]
      value: 'Benny: "So as we all know Coral is an animal, and they live happily
        with an algae called zooxanthelae"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[18]
      value: 'Benny: "The zooxanthelae is actually what gives all these coral their
        vibrant colors!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[19]
      value: 'Player: "Oh that''s so cool! So the coral and zooxanthelae are like
        roommates!?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[20]
      value: 'Benny: "Yup, and they both need each other to live, the zooxanthelae
        gives the coral food and the coral gives zooxanthelae a home!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[21]
      value: 'Benny: "But when the water starts becoming too warm, the coral starts
        getting hot and uncomfortable" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[22]
      value: 'Benny: "And because it''s so hot, it lets go of all the zooxanthelae,
        thinking that thats the cause of them being so hot"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[23]
      value: 'Player: "So kinda like when you are hot and you take off your jacket??" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[24]
      value: 'Benny: "Exactly! But they need each other, so the coral ends up losing
        its color and starving :(" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[25]
      value: 'Player: "Oh No! Thats so sad..."'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[26]
      value: 'Player: "is there anything we can do to try and help them?" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[27]
      value: 'Benny: "Well if the world was to switch to renewable energy, instead
        of Fossil fuels, we would be able to reverse climate change and save our
        oceans" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[28]
      value: 'Player: "Wait, what is renewable energy??"'
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[29]
      value: 'Benny: "It''s basically clean energy from Earths natural resources,
        like wind, water, and the sun!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[30]
      value: 'Benny: "I''ve been waiting for our town to switch to renewable energy,
        but I can''t get anyone to listen to me" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[31]
      value: 'Player: "What!?!?! That''s ridiculous, do they even know how important
        this is" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[32]
      value: 'Benny: "I don''t think anyone actually knows the damage that''s being
        done" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[33]
      value: 'Player: "This is crazy! I''m going to see if I can talk to the mayor!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[34]
      value: 'Player: "Thanks for letting me know what''s going on, see you around" '
      objectReference: {fileID: 0}
    - target: {fileID: 2641175210428784259, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: dialogue.Array.data[35]
      value: 'Benny: "No problem, bye and good luck!!" '
      objectReference: {fileID: 0}
    - target: {fileID: 2741854173681740130, guid: 2ed84303b3c1c3b44a85ef4e464a50c5, type: 3}
      propertyPath: m_LocalScale.x
