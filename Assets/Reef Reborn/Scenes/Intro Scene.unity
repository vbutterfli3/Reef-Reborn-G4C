  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6329385acce3f6c4fb6a150da23c72fa, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueText: {fileID: 311244758}
  lines:
  - < Press E to Continue >
  - 'Player: "Anddd I booked my ticket!"'
  - 'Player: "I can''t believe I''m going to be in Australia for the whole summer!!"'
  - 'Player: "I heard they have the most gorgeous coral reefs"'
  - 'Player: "Oooo I should watch some videos to see what I''m getting myself into"'
  - 'Player: "I can''t wait to dive in and see!!"'
  - 'Player: "What to pack... what to pack..."'
  - 'Player: "My scuba gear!"'
  - 'Mom: "Honey!!!"'
  - 'Player: "Yes Mom??"'
  - 'Mom: "Don''t you think you should do a little more research and start packing?"'
  - 'Mom: "I mean, you''re gonna be there for a while right?'''
  - 'Player: "I just started packing, but I''ll be fine"'
  - 'Mom: "Okay Sweety"'
  nextSceneName: Main Scene
